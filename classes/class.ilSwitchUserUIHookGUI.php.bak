<?php

declare(strict_types=1);

/**
 * UI hook and goto handler for the ILIAS 10 SwitchUser plugin.
 */
class ilSwitchUserUIHookGUI extends ilUIHookPluginGUI
{
    private const SESSION_ACCOUNT_ID = 'AccountId';
    private const SESSION_AUTH_USER_ID = '_authsession_user_id';
    private const SESSION_ORIGINAL_USER_ID = 'switch_user_original_user_id';
    private const SESSION_ORIGINAL_USER_LOGIN = 'switch_user_original_user_login';

    private static bool $message_rendered = false;
    private static bool $menu_script_rendered = false;

    public function gotoHook(): void
    {
        global $DIC;

        $request = $DIC->http()->wrapper()->query();
        if (!$request->has('target')) {
            return;
        }

        $target = $request->retrieve('target', $DIC->refinery()->kindlyTo()->string());

        if ($target === ilSwitchUserPlugin::TARGET_OPEN) {
            $this->openSearchPage();
        }

        if ($target !== ilSwitchUserPlugin::TARGET_TAKEOVER) {
            return;
        }

        if (!$request->has('user_id')) {
            $this->openSearchPage();
        }

        $user_id = $request->retrieve('user_id', $DIC->refinery()->kindlyTo()->int());
        if ($user_id <= 0) {
            $DIC->ui()->mainTemplate()->setOnScreenMessage('failure', $this->txt('msg_user_not_found'), true);
            $this->redirectToReferrerOrDashboard();
        }

        if ($this->isImpersonationActive()) {
            $original_user_id = $this->getOriginalUserId();
            if ($original_user_id !== null && $original_user_id === $user_id) {
                $this->stopImpersonation($original_user_id);
            }

            $DIC->ui()->mainTemplate()->setOnScreenMessage('failure', $this->txt('msg_invalid_stop'), true);
            $this->redirectToDashboard();
        }

        if (!$this->isAdministrativeUser()) {
            $DIC->ui()->mainTemplate()->setOnScreenMessage('failure', $this->txt('msg_no_permission'), true);
            $this->redirectToReferrerOrDashboard();
        }

        if (!ilObject::_exists($user_id, false, 'usr')) {
            $DIC->ui()->mainTemplate()->setOnScreenMessage('failure', $this->txt('msg_user_not_found'), true);
            $this->redirectToReferrerOrDashboard();
        }

        $target_user = new ilObjUser($user_id);
        $current_user = $DIC->user();

        if ($target_user->getId() === ANONYMOUS_USER_ID) {
            $DIC->ui()->mainTemplate()->setOnScreenMessage('failure', $this->txt('msg_user_not_found'), true);
            $this->redirectToReferrerOrDashboard();
        }

        if ($target_user->getId() === $current_user->getId()) {
            $DIC->ui()->mainTemplate()->setOnScreenMessage('failure', $this->txt('msg_same_user'), true);
            $this->redirectToReferrerOrDashboard();
        }

        $this->startImpersonation($target_user);
    }

    public function getHTML(string $a_comp, string $a_part, array $a_par = []): array
    {
        $html = '';

        if ($this->shouldRenderInjectionScripts($a_comp, $a_part)) {
            if ($this->isImpersonationActive() && !self::$message_rendered) {
                $original_user_id = $this->getOriginalUserId();
                if ($original_user_id !== null) {
                    $link = ilUtil::appendUrlParameterString(
                        'goto.php',
                        'target=' . rawurlencode(ilSwitchUserPlugin::TARGET_TAKEOVER) . '&user_id=' . $original_user_id
                    );
                    $login = (string) ($_SESSION[self::SESSION_ORIGINAL_USER_LOGIN] ?? ('#' . $original_user_id));
                    $message = sprintf(
                        $this->txt('msg_active_impersonation'),
                        $link,
                        htmlspecialchars($login, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8')
                    );

                    self::$message_rendered = true;
                    $html .= $this->buildImpersonationBannerScript($message);
                }
            }

            if (!self::$menu_script_rendered && $this->shouldInjectUsersRolesMenu()) {
                self::$menu_script_rendered = true;
                $html .= $this->buildUsersRolesMenuScript(
                    ilUtil::appendUrlParameterString('goto.php', 'target=' . rawurlencode(ilSwitchUserPlugin::TARGET_OPEN))
                );
            }
        }

        if ($html === '') {
            return [
                'mode' => self::KEEP,
                'html' => ''
            ];
        }

        return [
            'mode' => self::APPEND,
            'html' => $html
        ];
    }

    private function shouldRenderInjectionScripts(string $a_comp, string $a_part): bool
    {
        if ($a_comp === 'Services/MainMenu' && $a_part === 'main_menu_list_entries') {
            return true;
        }

        if ($a_comp === 'Services/Locator' && $a_part === 'main_locator') {
            return true;
        }

        return false;
    }

    private function shouldInjectUsersRolesMenu(): bool
    {
        global $DIC;

        if (!$this->isAdministrativeUser()) {
            return false;
        }

        $request = $DIC->http()->wrapper()->query();
        $base_class = $request->has('baseClass')
            ? strtolower((string) $request->retrieve('baseClass', $DIC->refinery()->kindlyTo()->string()))
            : '';
        $cmd_class = $request->has('cmdClass')
            ? strtolower((string) $request->retrieve('cmdClass', $DIC->refinery()->kindlyTo()->string()))
            : '';

        if ($base_class === '' || $base_class === 'ilstartupgui') {
            return false;
        }

        if ($cmd_class === 'ilobjcomponentsettingsgui' || $cmd_class === 'ilswitchuserconfiggui') {
            return false;
        }

        if (isset($_GET['plugin_id']) && (string) $_GET['plugin_id'] === ilSwitchUserPlugin::PLUGIN_ID) {
            return false;
        }

        return true;
    }

    private function buildUsersRolesMenuScript(string $url): string
    {
        $payload = json_encode([
            'url' => $url,
            'title' => $this->txt('admin_menu_title'),
            'panel_titles' => [
                'users and roles',
                'utilisateurs et rôles',
                'utilisateurs et roles',
                'benutzer und rollen',
                'utenti e ruoli'
            ],
            'reference_labels' => [
                'privacy and security',
                'confidentialité et sécurité',
                'confidentialite et securite',
                'confidenzialità e sicurezza',
                'datenschutz und sicherheit'
            ],
            'fallback_labels' => [
                'authentication / account registration',
                'authentification / nouvelle inscription',
                'autenticazione / nuova registrazione',
                'authentifizierung / registrierung'
            ]
        ], JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT);

        return <<<HTML
<script>
(function () {
    if (window.__switchUserUsersRolesMenuScript) {
        return;
    }
    window.__switchUserUsersRolesMenuScript = true;

    var cfg = {$payload};

    function normalize(value) {
        var text = (value || '').toString().toLowerCase();
        if (text.normalize) {
            text = text.normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        }
        return text.replace(/\s+/g, ' ').trim();
    }

    function matchesOne(value, labels) {
        var text = normalize(value);
        for (var i = 0; i < labels.length; i++) {
            if (text.indexOf(normalize(labels[i])) !== -1) {
                return true;
            }
        }
        return false;
    }

    function allNodes(selector) {
        try {
            return document.querySelectorAll(selector);
        } catch (e) {
            return [];
        }
    }

    function findLabelNode(labels) {
        var nodes = allNodes('a, button, [role="button"], li, div, span, h1, h2, h3');
        for (var i = 0; i < nodes.length; i++) {
            var node = nodes[i];
            if (!node || node.getAttribute('data-switchuser-admin-link') === '1') {
                continue;
            }
            if (matchesOne(node.textContent || '', labels)) {
                return node;
            }
        }
        return null;
    }

    function findClickableRow(startNode) {
        var node = startNode;
        while (node && node !== document.body) {
            if (node.matches && node.matches('a[href], button, [role="button"]')) {
                return node;
            }
            if (node.parentNode) {
                var links = node.parentNode.querySelectorAll ? node.parentNode.querySelectorAll('a[href], button, [role="button"]') : [];
                if (links && links.length >= 1) {
                    for (var i = 0; i < links.length; i++) {
                        if (links[i].contains(node) || links[i] === node) {
                            return links[i];
                        }
                    }
                }
            }
            node = node.parentNode;
        }
        return startNode;
    }

    function replaceText(node, labels, title) {
        if (!node) {
            return false;
        }

        var queue = [node];
        while (queue.length > 0) {
            var current = queue.shift();
            if (!current) {
                continue;
            }

            if (current.childNodes && current.childNodes.length > 0) {
                for (var i = 0; i < current.childNodes.length; i++) {
                    var child = current.childNodes[i];
                    if (child.nodeType === 3 && matchesOne(child.nodeValue || '', labels)) {
                        child.nodeValue = title;
                        return true;
                    }
                    if (child.nodeType === 1) {
                        queue.push(child);
                    }
                }
            }
        }

        if (matchesOne(node.textContent || '', labels)) {
            node.textContent = title;
            return true;
        }

        return false;
    }

    function wireLink(node) {
        if (!node) {
            return;
        }

        node.setAttribute('data-switchuser-admin-link', '1');
        if (node.matches && node.matches('a')) {
            node.href = cfg.url;
            node.target = '_self';
            return;
        }

        var anchor = node.querySelector ? node.querySelector('a[href]') : null;
        if (anchor) {
            anchor.href = cfg.url;
            anchor.target = '_self';
            return;
        }

        node.style.cursor = 'pointer';
        node.addEventListener('click', function (event) {
            event.preventDefault();
            window.location.href = cfg.url;
        });
    }

    function makeFromSource(sourceNode, labelsForReplacement) {
        var row = findClickableRow(sourceNode);
        if (!row) {
            return null;
        }

        var clone = row.cloneNode(true);
        clone.removeAttribute('id');
        clone.setAttribute('data-switchuser-admin-link', '1');
        wireLink(clone);
        if (!replaceText(clone, labelsForReplacement, cfg.title)) {
            if (!replaceText(clone, cfg.fallback_labels, cfg.title)) {
                clone.appendChild(document.createTextNode(cfg.title));
            }
        }
        return { source: row, node: clone };
    }

    function inject() {
        if (document.querySelector('[data-switchuser-admin-link="1"]')) {
            return true;
        }

        var panelTitle = findLabelNode(cfg.panel_titles);
        if (!panelTitle) {
            return false;
        }

        var refNode = findLabelNode(cfg.reference_labels);
        if (refNode) {
            var made = makeFromSource(refNode, cfg.reference_labels);
            if (made && made.source.parentNode) {
                made.source.parentNode.insertBefore(made.node, made.source.nextSibling);
                return true;
            }
        }

        var fallbackNode = findLabelNode(cfg.fallback_labels);
        if (fallbackNode) {
            var fallbackMade = makeFromSource(fallbackNode, cfg.fallback_labels);
            if (fallbackMade && fallbackMade.source.parentNode) {
                fallbackMade.source.parentNode.insertBefore(fallbackMade.node, fallbackMade.source.nextSibling);
                return true;
            }
        }

        var panel = panelTitle;
        while (panel && panel !== document.body) {
            var clickable = panel.querySelectorAll ? panel.querySelectorAll('a[href], button, [role="button"]') : [];
            if (clickable && clickable.length >= 3) {
                var last = clickable[clickable.length - 1];
                var generic = makeFromSource(last, [last.textContent || '']);
                if (generic && generic.source.parentNode) {
                    generic.source.parentNode.insertBefore(generic.node, generic.source.nextSibling);
                    return true;
                }
            }
            panel = panel.parentNode;
        }

        return false;
    }

    function run() {
        inject();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', run);
    } else {
        run();
    }

    var observer = new MutationObserver(function () {
        run();
    });
    observer.observe(document.documentElement, { childList: true, subtree: true });
})();
</script>
HTML;
    }

    private function buildImpersonationBannerScript(string $message): string
    {
        $message_html = json_encode($message, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT);

        return <<<HTML
<script>
(function () {
    if (window.__switchUserBannerInjected) {
        return;
    }
    window.__switchUserBannerInjected = true;

    var renderBanner = function () {
        if (!document.body || document.getElementById('switch-user-banner')) {
            return;
        }

        var banner = document.createElement('div');
        banner.id = 'switch-user-banner';
        banner.style.position = 'fixed';
        banner.style.top = '0';
        banner.style.left = '0';
        banner.style.right = '0';
        banner.style.zIndex = '100000';
        banner.style.background = '#7a1212';
        banner.style.color = '#ffffff';
        banner.style.padding = '10px 16px';
        banner.style.textAlign = 'center';
        banner.style.fontSize = '14px';
        banner.style.lineHeight = '1.4';
        banner.style.boxShadow = '0 2px 6px rgba(0,0,0,.2)';
        banner.innerHTML = {$message_html};

        var links = banner.getElementsByTagName('a');
        for (var i = 0; i < links.length; i++) {
            links[i].style.color = '#ffffff';
            links[i].style.fontWeight = '700';
            links[i].style.textDecoration = 'underline';
        }

        document.body.insertBefore(banner, document.body.firstChild);
    };

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderBanner);
    } else {
        renderBanner();
    }
})();
</script>
HTML;
    }

    private function openSearchPage(): void
    {
        global $DIC;

        if (!$this->isAdministrativeUser()) {
            $DIC->ui()->mainTemplate()->setOnScreenMessage('failure', $this->txt('msg_no_permission'), true);
            $this->redirectToReferrerOrDashboard();
        }

        $term = '';
        $rows = [];
        if (strtoupper((string) $DIC->http()->request()->getMethod()) === 'POST') {
            $term = trim((string) ($_POST['query'] ?? ''));
            $rows = $this->searchPage()->findUsers($term);
        }

        $tpl = $DIC->ui()->mainTemplate();
        $tpl->setTitle($this->txt('admin_menu_title'));
        if (method_exists($tpl, 'setDescription')) {
            $tpl->setDescription($this->txt('admin_menu_hint'));
        }
        $tpl->setContent(
            $this->searchPage()->render(
                ilUtil::appendUrlParameterString('goto.php', 'target=' . rawurlencode(ilSwitchUserPlugin::TARGET_OPEN)),
                $term,
                $rows
            )
        );

        if (method_exists($tpl, 'printToStdout')) {
            $tpl->printToStdout();
        } elseif (method_exists($tpl, 'show')) {
            $tpl->show();
        }
        exit;
    }

    private function searchPage(): ilSwitchUserSearchPage
    {
        return new ilSwitchUserSearchPage($this->getPluginObject() instanceof ilSwitchUserPlugin ? $this->getPluginObject() : null);
    }

    private function txt(string $key): string
    {
        $plugin = $this->getPluginObject();
        return $plugin ? $plugin->txt($key) : $key;
    }

    private function startImpersonation(ilObjUser $target_user): void
    {
        global $DIC;

        $current_user = $DIC->user();
        $_SESSION[self::SESSION_ORIGINAL_USER_ID] = (int) $current_user->getId();
        $_SESSION[self::SESSION_ORIGINAL_USER_LOGIN] = (string) $current_user->getLogin();
        $_SESSION[self::SESSION_ACCOUNT_ID] = (int) $target_user->getId();
        $_SESSION[self::SESSION_AUTH_USER_ID] = (int) $target_user->getId();

        session_write_close();

        $message = sprintf(
            $this->txt('msg_takeover_started'),
            htmlspecialchars($target_user->getLogin(), ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8')
        );
        $DIC->ui()->mainTemplate()->setOnScreenMessage('success', $message, true);
        $this->redirectToDashboard();
    }

    private function stopImpersonation(int $original_user_id): void
    {
        global $DIC;

        $original_user = new ilObjUser($original_user_id);
        unset($_SESSION[self::SESSION_ORIGINAL_USER_ID], $_SESSION[self::SESSION_ORIGINAL_USER_LOGIN]);
        $_SESSION[self::SESSION_ACCOUNT_ID] = $original_user_id;
        $_SESSION[self::SESSION_AUTH_USER_ID] = $original_user_id;

        session_write_close();

        $message = sprintf(
            $this->txt('msg_takeover_stopped'),
            htmlspecialchars($original_user->getLogin(), ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8')
        );
        $DIC->ui()->mainTemplate()->setOnScreenMessage('success', $message, true);
        $this->redirectToDashboard();
    }

    private function isImpersonationActive(): bool
    {
        $original_user_id = $this->getOriginalUserId();
        if ($original_user_id === null) {
            return false;
        }

        global $DIC;
        return (int) $DIC->user()->getId() !== $original_user_id;
    }

    private function getOriginalUserId(): ?int
    {
        if (!isset($_SESSION[self::SESSION_ORIGINAL_USER_ID])) {
            return null;
        }

        return (int) $_SESSION[self::SESSION_ORIGINAL_USER_ID];
    }

    private function isAdministrativeUser(): bool
    {
        if (method_exists('ilUtil', 'checkAdmin')) {
            return (bool) ilUtil::checkAdmin();
        }

        global $DIC;
        $roles = $DIC->rbac()->review()->assignedRoles((int) $DIC->user()->getId());
        return in_array(SYSTEM_ROLE_ID, $roles, true);
    }

    private function redirectToReferrerOrDashboard(): void
    {
        global $DIC;

        $referer = $DIC->http()->request()->getHeaderLine('referer');
        if ($referer !== '') {
            $DIC->ctrl()->redirectToURL($referer);
        }

        $this->redirectToDashboard();
    }

    private function redirectToDashboard(): void
    {
        global $DIC;
        $DIC->ctrl()->redirectByClass('ildashboardgui', 'jumpToSelectedItems');
        exit;
    }
}
